{
  "name": "tokenkit",
  "version": "0.2.0",
  "description": "Unified token counting and cost estimation for AI providers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "try:openai": "npx tsx scripts/try-api.ts",
    "try:all": "npx tsx scripts/try-all.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tokens",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "pricing"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "tiktoken": "^1.0.22"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/genai": "^2.6.0",
    "@types/node": "^22.15.21",
    "ai": "^6.0.191",
    "dotenv": "^17.4.2",
    "openai": "^6.39.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeSquar/tokenkit.git"
  },
  "bugs": {
    "url": "https://github.com/CodeSquar/tokenkit/issues"
  }
}
